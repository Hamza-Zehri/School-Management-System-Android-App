# The .dart_tool/ directory is generated by the "pub" version-solving mechanism.
# It contains information about your package's dependencies, as well as intermediate
# build artifacts.
.dart_tool/

# Flutter/Dart/Pub related
# .lock files are usually committed to git for applications, but the user requested "all changes".
# I'll keep pubspec.lock since it's already modified.
.packages
.pub-cache/
.pub/
build/

